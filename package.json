{
  "name": "meetmind",
  "version": "1.0.0",
  "private": true,
  "description": "MeetMind — A zero-backend, browser-based screen recorder that captures your screen with system audio, converts recordings to high-quality MP4 using ffmpeg.wasm, and generates transcripts with Whisper AI — all running locally in your browser. No uploads, no cloud, no subscriptions.",
  "keywords": [
    "screen-recording",
    "screen-capture",
    "transcription",
    "whisper",
    "ffmpeg",
    "webm-to-mp4",
    "speech-to-text",
    "meeting-recorder",
    "no-upload",
    "privacy-first",
    "nextjs",
    "typescript",
    "tailwindcss"
  ],
  "author": "Hari Krishna <anemharikrishna@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HariKrishna-9885699666/meeting-mind.git"
  },
  "bugs": {
    "url": "https://github.com/HariKrishna-9885699666/meeting-mind/issues"
  },
  "homepage": "https://github.com/HariKrishna-9885699666/meeting-mind#readme",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.6",
    "@ffmpeg/util": "^0.12.1",
    "@xenova/transformers": "^2.17.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.8",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "ignore-loader": "^0.1.2",
    "onnxruntime-web": "^1.26.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "Chrome >= 94",
    "Edge >= 94"
  ]
}
